{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "configFile": "railway.nix"
    }
  },
  "deploy": {
    "startCommand": "cd backend && python app.py",
    "healthcheckPath": "/api/health",
    "restartPolicy": {
      "type": "ON_FAILURE"
    }
  }
}